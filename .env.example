# Benchmark CLI runtime defaults
# Loaded automatically by cli/config.py (order: .env.local, then .env)

# Scratch/workspace
BENCHMARK_SCRATCH_WORKSPACE=/fs/cml-scratch/ishaank/benchmark_cli
BENCHMARK_DATASET_ROOT=/fs/cml-scratch/ishaank/benchmark_cli/benchmark_cli/datasets
BENCHMARK_RESULTS_ROOT=/fs/cml-scratch/ishaank/benchmark_cli/benchmark_cli/results
BENCHMARK_CACHE_DIR=/fs/cml-scratch/ishaank/benchmark_cli/benchmark_cli/cache/retrieval_embeddings
BENCHMARK_REPOEVAL_DATASET_PATH=/fs/cml-scratch/ishaank/benchmark_cli/benchmark_cli/datasets/repoeval_metadata/function_level_completion_2k_context_codex.test.clean.jsonl

# Slurm defaults
BENCHMARK_SLURM_PARTITION=scavenger
BENCHMARK_SLURM_ACCOUNT=scavenger
BENCHMARK_SLURM_QOS=scavenger
BENCHMARK_SLURM_TIME=04:00:00
BENCHMARK_SLURM_MEM=32G
BENCHMARK_SLURM_GPUS=1
BENCHMARK_SLURM_CPUS_PER_TASK=1
# Optional per-run pinning
# BENCHMARK_SLURM_NODELIST=clip04
# BENCHMARK_SLURM_CONSTRAINT=h100

# Model/runtime defaults
BENCHMARK_BATCH_SIZE=16
BENCHMARK_SLURM_POLL_INTERVAL_SEC=10

# If using uv, set this in shell before uv starts (CLI cannot retroactively affect uv itself)
UV_CACHE_DIR=/fs/cml-scratch/ishaank/home_cache/uv
